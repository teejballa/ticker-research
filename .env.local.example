# .env.local.example
# Copy to .env.local and fill in your values.
# Then run: npm install && npm start

# Required: Anthropic API key for data collection
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Set to 'cloud' when deploying to Vercel
# DEPLOYMENT_MODE=local

# Optional (cloud mode only): URL of your Cloud Run container
# CONTAINER_URL=https://ticker-research-container-xxxx-uc.a.run.app

# Optional (cloud mode only): Shared secret to authenticate Vercel→container requests
# CONTAINER_SECRET=a-long-random-string

# Phase 6 — Web Mode (DEPLOYMENT_MODE=web)
# Set DEPLOYMENT_MODE=web in Vercel environment variables to enable web mode.
# All variables below are required ONLY when DEPLOYMENT_MODE=web.

# Google OAuth — create at console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs:
#   https://your-app.vercel.app/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google (for local dev)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# NextAuth URL — set to your Vercel deployment URL in production
# For local development: http://localhost:3000
NEXTAUTH_URL=https://your-app.vercel.app

# Neon PostgreSQL — create project at neon.tech
# Use the POOLED connection string for DATABASE_URL (hostname contains "-pooler")
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=10

# Use the DIRECT (non-pooled) connection string for DIRECT_URL (for Prisma migrations)
DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Deployment mode: set to 'web' for Vercel + Neon + Google Auth mode
# Leave unset (or set to 'local') for local filesystem + notebooklm-py mode
DEPLOYMENT_MODE=web
# Required alongside DEPLOYMENT_MODE=web — exposes web mode flag to client-side components (SetupWizard guard)
NEXT_PUBLIC_DEPLOYMENT_MODE=web

# Phase 9: Container Env Vars (set in Vercel dashboard → Project Settings → Environment Variables)
# These are read by the Next.js frontend running on Vercel:
#
# Cloud Run service URL — get with:
#   gcloud run services describe ticker-research-container --region=us-central1 --format='value(status.url)'
CONTAINER_URL=https://ticker-research-container-xxxx-uc.a.run.app
# Shared secret — must match CONTAINER_SECRET env var set on the Cloud Run service
CONTAINER_SECRET=your-shared-secret-here
# VNC WebSocket URL — MUST use wss:// and path /vnc-ws (NOT a :6080 port URL)
# Cloud Run exposes only one port (8080/443); the /vnc-ws path proxies VNC through it
CONTAINER_VNC_URL=wss://ticker-research-container-xxxx-uc.a.run.app/vnc-ws

# Phase 8: NbLM Credential Encryption (generate with: openssl rand -hex 32)
# WARNING: Never regenerate this key — existing stored credentials will become unreadable
CREDENTIAL_ENCRYPTION_KEY=your-64-char-hex-key-here

# Vercel Go-Live Checklist — 12 env vars set in Vercel dashboard (NOT in .env.local):
# 1. DATABASE_URL=<neon-connection-string>
# 2. NEXTAUTH_SECRET=<random-32-byte-hex>
# 3. NEXTAUTH_URL=https://your-app.vercel.app
# 4. GOOGLE_CLIENT_ID=<from-google-cloud-console>
# 5. GOOGLE_CLIENT_SECRET=<from-google-cloud-console>
# 6. ANTHROPIC_API_KEY=<your-api-key>
# 7. DEPLOYMENT_MODE=web
# 8. NEXT_PUBLIC_DEPLOYMENT_MODE=web
# 9. CONTAINER_URL=<cloud-run-service-url>
# 10. CONTAINER_SECRET=<shared-secret>
# 11. CONTAINER_VNC_URL=wss://<service-url>/vnc-ws  (must use wss:// + /vnc-ws path — not a :6080 port URL)
# 12. CREDENTIAL_ENCRYPTION_KEY=<64-char-hex>
# Google OAuth: add https://your-app.vercel.app/api/auth/callback/google to authorized redirect URIs

# Cloud Run Container Env Vars — 2 env vars set INSIDE the Cloud Run service (NOT in Vercel):
# These are read by scripts/container_server.py running inside the container:
# CONTAINER_SECRET=<same-shared-secret-as-Vercel>  (validates incoming requests via x-container-secret header)
# ALLOWED_ORIGIN=https://your-app.vercel.app        (FastAPI CORS allowed origin — Vercel domain only)

# Phase 10: Supplementary Market Data Sources (all optional — pipeline works without them)
# Each source runs in parallel on every research request and adds data to NotebookLM.
# Sign up for free API keys at the links below — no credit card required.

# Finnhub — 60 calls/min free: https://finnhub.io/register
# Covers: company profile, market cap, P/E, EPS, P/B, revenue, debt/equity, ROE, ROA
FINNHUB_API_KEY=

# Polygon.io — unlimited free tier (delayed data): https://polygon.io/dashboard/signup
# Covers: ticker details, SEC financial statements (income statement, balance sheet)
POLYGON_API_KEY=
