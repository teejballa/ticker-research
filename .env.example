ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Phase 6 — Web Mode (DEPLOYMENT_MODE=web)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-app.vercel.app
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=10
DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DEPLOYMENT_MODE=web

# Phase 19 — feature flags (off | shadow | true)
FEATURE_CONFORMAL=off
FEATURE_CPCV=off
FEATURE_IC_DECAY_MONITOR=off
FEATURE_HIERARCHICAL_POOLING=off
FEATURE_DATA_CACHE=off
FEATURE_TWELVEDATA_PRIMARY=off
FEATURE_EXA_PRIMARY=off
FEATURE_FINSENTLLM_ENSEMBLE=off
FEATURE_COMMUNITY_SUPPLEMENTAL=off
FEATURE_COVE_TWO_PASS=off
FEATURE_MODEL_ROUTER=off
FEATURE_CONTRADICTION_DETECTOR=off
FEATURE_OPTIONS_TERM_STRUCTURE=off
FEATURE_REPUTATION_WEIGHTED_STOCKTWITS=off

# Phase 19-C-11 — Arctic Shift one-time historical Reddit backfill (D-43).
# Optional: API authentication for Arctic Shift (https://arctic-shift.photon-reddit.com/).
# Currently the public endpoint does not require auth, but if rate-limit
# tightens, set this and the backfill script will forward as Bearer header.
ARCTIC_SHIFT_KEY=

# Phase 19-B-01 — Upstash Redis cache layer (graceful degrade if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Phase 19-B-04 — Twelve Data (fundamentals; $29/mo)
TWELVEDATA_API_KEY=

# Phase 19-B-05 — Exa 2.0 (semantic news/analyst search; ~$5/mo)
EXA_API_KEY=

# Phase 19-C-01 — HuggingFace Inference Endpoints (~$10/mo total)
# NOTE: 3 endpoints must be provisioned BEFORE this code runs in production.
# Per RESEARCH §Environment Availability, endpoints not yet provisioned as of 2026-05-06.
# Endpoint URLs MUST include @<commit-sha> revision pin (RESEARCH Open Question 1).
HF_INFERENCE_TOKEN=
HF_FINGPT_ENDPOINT=
HF_MISTRAL_FIN_ENDPOINT=

# ProsusAI/finbert per-message backstop (Phase 20-B-02). Provisioned on HF Inference Endpoints,
# cpu-medium ($0.033/hr) instance, region us-east-1. URL MUST include @<pinned-commit-sha>
# per 19-C-01 / 20-B-02 SHA-pinning convention. Re-pin requires bumping FINBERT_PINNED_SHA8
# in src/lib/sentiment/finsentllm.ts AND bumping the model_version suffix from -v1 to -v2
# so 20-Z-01 SentimentObservation rows partition cleanly.
#
# Format:
#   HF_FINBERT_ENDPOINT=https://<id>.us-east-1.aws.endpoints.huggingface.cloud/<pinned-sha-or-revision-id>
HF_FINBERT_ENDPOINT=

# Phase 20-B-02 shadow flag — three modes per S3:
#   off    — per-message pass disabled; existing snapshot path unchanged
#   shadow — per-message pass runs, persists to SentimentObservation, no read consumers yet
#   on     — downstream aggregation (20-A-03 / 20-B-04) consumes the rows
PER_MESSAGE_PASS_MODE=off

# Phase 19-C-06 — Quiver Hobbyist (insider + congressional; optional, ~$30/mo)
# Adapter only activates when this is set. Leave blank to skip.
QUIVER_API_KEY=

# Plan 20-D-03 — Per-claim CoVe verification + UI (?) badge.
# Three modes per S3:
#   off    — per-claim verifier never runs; AnalysisResult.bullish_signals[*].verified
#            stays undefined; UI badge never renders. Bit-identical to pre-plan today.
#   shadow — verifier runs, verdicts persist onto AnalysisResult; UI badge stays hidden.
#            Operator inspects via SQL on Report.analysis JSONB. Cutover criteria in
#            20-D-03-PLAN.md frontmatter shadow_lifecycle.cutover_criteria.
#   on     — verdicts persist AND UI badge renders for verified ∈ {false, null}.
FEATURE_PER_CLAIM_VERIFIED=off

# Client-side surface for the (?) badge gate in ResearchReport.tsx. Set to 'on'
# only after FEATURE_PER_CLAIM_VERIFIED=on AND the 4 cutover criteria pass.
NEXT_PUBLIC_FEATURE_PER_CLAIM_VERIFIED=off

# Phase 30.1-pivot — Xpoz Pro key for Reddit + Twitter community scraping (D-32).
# Reddit closed self-service API in 2025 (Responsible Builder Policy bars commercial
# + ML + sentiment use). Xpoz Pro ($16/mo + $0.80/1K credit overage) is the unified
# replacement covering Reddit + Twitter (+ IG/TikTok deferred). Sign up at https://xpoz.ai.
XPOZ_API_KEY=

## Sentiment Feature Store (PIT)
# Phase 30.1 (D-17) — deployment-secret pepper for SHA-256 author hashing.
# Empty default is OK in dev; production MUST set a non-trivial value.
# Same pepper used for both Reddit and HackerNews author hashes. Phase 20-Z-01's
# StockTwits writer does not yet read this — retrofit deferred to a follow-up.
# Rotation: changing this pepper requires bumping model_version from
# {source}-tag-v1 → {source}-tag-v2 (author_id partitioning is per model_version).
SENTIMENT_AUTHOR_PEPPER=

# Phase 30.1-pivot — community-scan source switch (D-36).
# Values: firecrawl (legacy, default), xpoz (new path), shadow (Xpoz runs but writes nowhere).
FEATURE_COMMUNITY_SCAN_SOURCE=firecrawl
