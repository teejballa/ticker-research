# ========================
# System / OS files
# ========================
.DS_Store
Thumbs.db

# ========================
# Python
# ========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.venv
.env/
venv/

# ========================
# Node / JavaScript
# ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ========================
# Next.js
# ========================
.next/
out/
build/

# ========================
# Environment files — never commit secrets
# ========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========================
# Research artifacts — never commit generated source packages
# ========================
/tmp/ticker-research-*
*.research.json

# ========================
# Logs
# ========================
*.log

# ========================
# Claude Code / NotebookLM generated files
# ========================
*.pdf
*.tmp
*.csv
*.ipynb_checkpoints/

# Allow planning docs in version control
!.planning/*.json
!.planning/**/*.json

# ========================
# Editor / IDE files
# ========================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ========================
# MacOS specific
# ========================
.DS_Store

# ========================
# Other temp / cache files
# ========================
*.bak
*.swp
*.swo

# ========================
# TypeScript
# ========================
*.tsbuildinfo
next-env.d.ts
.vercel
.claude/
.env*.local
