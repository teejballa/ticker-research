# ========================
# System / OS files
# ========================
.DS_Store
Thumbs.db

# ========================
# Python
# ========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.venv
.env/
venv/

# ========================
# Node / JavaScript
# ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ========================
# Next.js
# ========================
.next/
out/
build/

# ========================
# Environment files — never commit secrets
# ========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========================
# Research artifacts — never commit generated source packages
# ========================
/tmp/ticker-research-*
*.research.json

# ========================
# Logs
# ========================
*.log

# ========================
# Generated research artifacts
# ========================
*.pdf
*.tmp
*.csv
*.ipynb_checkpoints/

# Allow planning docs in version control
!.planning/*.json
!.planning/**/*.json

# Plan 20-B-01 — held-out eval datasets MUST be physically present in the repo
# (Mitchell-2019 model card reproducibility + the FPB ECE ship gate).
!data/eval/*.csv

# Plan 20-B-06 — L&M Master Dictionary is a static reference asset (committed,
# not generated). classifier_version reproducibility from commit SHA.
!data/lexicons/*.csv

# Plan 20-B-03 — Financial PhraseBank CSV is research input data, NOT a generated
# artifact (Malo et al. 2014, Araci 2019 partition; CC-BY-NC-SA-3.0). Required
# for temperature-scaling calibration reproducibility.
!data/datasets/*.csv

# ========================
# Editor / IDE files
# ========================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ========================
# MacOS specific
# ========================
.DS_Store

# ========================
# Other temp / cache files
# ========================
*.bak
*.swp
*.swo

# ========================
# TypeScript
# ========================
*.tsbuildinfo
next-env.d.ts
.vercel
.claude/
.env*.local

# ========================
# Playwright / e2e artifacts (runtime output, never commit)
# ========================
test-results/
playwright-report/
playwright/.cache/

# ========================
# Phase 19 shadow A/B verdict artifacts (runtime output, never commit)
# ========================
shadow-reports/

# ========================
# Phase 19-A-06 calibration audit reports (runtime output, never commit)
# Per CLAUDE.md "Never store generated research artifacts inside the
# repository". Script writes to /tmp/calibration-reports/ — this entry is
# belt-and-suspender against an accidental local calibration-reports/
# being created at the repo root.
# ========================
calibration-reports/

# ========================
# Phase 20-C-02 — Brier evaluation artifacts
# ========================
# JSON written by the weekly /api/cron/eval-brier (and the scripts/eval-brier.ts
# CLI). Committed only on ship-gate failure as operator narratives (the .md
# variant is intentionally NOT gitignored — see scripts/eval-brier.ts).
/reports/brier-*.json

# ========================
# Phase 20-D-02 — Citation-coverage evaluation artifacts
# ========================
# JSON + Markdown written by the weekly /api/cron/eval-citation-coverage and
# the scripts/eval-citation-coverage.ts CLI. Runtime output — regenerated
# weekly. Never commit.
/reports/citation-coverage-*.json
/reports/citation-coverage-*.md

# ========================
# Phase 20-D-03 — Per-claim verification baseline artifacts
# ========================
# JSON written by scripts/measure-claim-verification.ts. The first run produces
# the canonical baseline file `reports/per-claim-verification-baseline-{date}.json`
# which IS the artifact of this plan and SHOULD be committed manually when
# captured against the 20-D-04 golden-ticker SourcePackages. Transient dev
# runs (different dates) are ignored — re-bless requires manual `git add -f`.
/reports/per-claim-verification-baseline-*.json
!/reports/per-claim-verification-baseline-blessed.json

# ========================
# Phase 30 D-25 — Provider health verdict reports
# ========================
# Generated by scripts/provider-health-report.ts (npm run provider-health-report).
# Operator-readable per-provider gate verdict. Regenerated on demand;
# NEVER committed (no fixed historical artifact value).
/reports/provider-health-*.md
.env.vercel.*
