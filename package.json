{
  "name": "ticker-research",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next build && next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:debug": "playwright test --project=debug",
    "debug": "node scripts/live-debug.mjs",
    "debug:signin": "node scripts/live-debug.mjs signin",
    "debug:setup": "node scripts/live-debug.mjs setup-status",
    "debug:pipeline": "node scripts/live-debug.mjs full-pipeline",
    "debug:record": "node scripts/live-debug.mjs full-pipeline --record --record-fps 500"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@anthropic-ai/sdk": "^0.78.0",
    "@mendable/firecrawl-js": "4.18.3",
    "@neondatabase/serverless": "^1.0.2",
    "@novnc/novnc": "^1.6.0",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vercel/analytics": "^2.0.1",
    "ai": "6.0.168",
    "fast-xml-parser": "^4.5.1",
    "lightweight-charts": "^5.1.0",
    "next": "^15.3.9",
    "next-auth": "^4.24.13",
    "prisma": "^7.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-vnc": "^3.2.0",
    "technicalindicators": "3.1.0",
