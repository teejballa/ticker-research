    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@xenova/transformers": "^2.17.2",
    "ai": "6.0.168",
    "exa-js": "^2.12.1",
    "fast-xml-parser": "^4.5.1",
    "lightweight-charts": "^5.1.0",
